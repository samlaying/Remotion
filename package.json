{
  "name": "remotion-workspace",
  "version": "1.0.0",
  "description": "Remotion Monorepo 工作区",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter project-remotion-guide dev",
    "dev:guide": "pnpm --filter project-remotion-guide dev",
    "dev:grid": "pnpm --filter project-tech-grid dev",
    "dev:card": "pnpm --filter project-3d-card dev",
    "build": "pnpm --filter project-remotion-guide build",
    "render": "pnpm --filter project-remotion-guide render",
    "preview": "pnpm --filter project-remotion-guide preview",
    "typecheck": "pnpm --filter project-remotion-guide typecheck",
    "render:all": "node scripts/render-all.js",
    "project": "node scripts/project-manager.js",
    "project:list": "node scripts/project-manager.js list",
    "project:create": "node scripts/project-manager.js create",
    "project:delete": "node scripts/project-manager.js delete"
  },
  "keywords": ["remotion", "video", "monorepo"],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
